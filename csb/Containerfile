# =============================================================================
# OpenClaw on OpenShift — RHEL AI (CSB) Variant
# File: csb/Containerfile
# Maintainer: Ryan Nix <ryan.nix@gmail.com>
#
# Build context: repo root (.)
# Build command:
#   podman build -f csb/Containerfile \
#     --build-arg CSB_BASE_IMAGE=registry.gitlab.com/.../aipcc-base-aarch64:ci_1 \
#     --build-arg OPENCLAW_EXTENSIONS=codex,diagnostics-otel \
#     -t ...:csb-aarch64-latest .
#
# Two-stage build:
#   builder  — UBI 10 Node.js 22 clones, compiles, and prunes OpenClaw
#   runtime  — RHEL AI base image with compiled dist only
#
# Same build pipeline as UBI 10 / Hummingbird variants, but the runtime
# layer is the RHEL AI agentic base image instead of UBI or Hummingbird.
# This gives full control over which extensions ship in the image.
#
# Requires authentication to registry.gitlab.com (pull secret).
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Builder — compile OpenClaw from source
# Uses UBI 10 Node.js 22 for build toolchain (same as UBI 10 variant).
# ---------------------------------------------------------------------------
FROM registry.access.redhat.com/ubi10/nodejs-22:latest AS builder

LABEL stage="builder"

USER root
WORKDIR /build

ENV CI=true

RUN dnf install -y \
      git \
      python3 \
      make \
      gcc \
      gcc-c++ && \
    dnf clean all && \
    rm -rf /var/cache/dnf

RUN npm install -g pnpm@latest

ARG OPENCLAW_REF=main
RUN git clone --depth 1 --branch "${OPENCLAW_REF}" https://github.com/openclaw/openclaw.git .

# Extension selection — falls back to pnpm build on older release tags.
ARG OPENCLAW_EXTENSIONS=""
RUN if [ -f scripts/lib/docker-plugin-selection.mjs ]; then \
      node scripts/lib/docker-plugin-selection.mjs extensions "${OPENCLAW_EXTENSIONS}" \
        > /tmp/openclaw-selected-plugin-dirs; \
      touch /tmp/openclaw-plugin-selection-supported; \
      echo "Selected extensions:" && cat /tmp/openclaw-selected-plugin-dirs; \
    elif [ -n "${OPENCLAW_EXTENSIONS}" ]; then \
      echo "ERROR: OPENCLAW_EXTENSIONS='${OPENCLAW_EXTENSIONS}' was requested but scripts/lib/docker-plugin-selection.mjs is not available on this ref" >&2; \
      exit 1; \
    else \
      echo "Extension selection script not available on this ref — all extensions will be built"; \
    fi

RUN pnpm install --no-frozen-lockfile

# Compile TypeScript → dist/
RUN set -eu; \
    if [ -f /tmp/openclaw-plugin-selection-supported ]; then \
      selected_plugin_dirs="$(cat /tmp/openclaw-selected-plugin-dirs)"; \
      OPENCLAW_INTERNAL_DOCKER_BUILD_PLUGIN_IDS="$selected_plugin_dirs" \
      OPENCLAW_RUN_NODE_SKIP_DTS_BUILD=1 \
      NODE_OPTIONS="--max-old-space-size=8192" \
      pnpm_config_verify_deps_before_run=false pnpm build:docker; \
    else \
      pnpm build; \
    fi
RUN pnpm_config_verify_deps_before_run=false pnpm ui:build || pnpm ui:build

# Resolve pnpm workspace symlinks to real copies BEFORE pruning.
# pnpm links workspace packages (e.g. @openclaw/ai → packages/ai) as symlinks.
# These must become real copies before we delete packages/ or prune deps.
RUN find node_modules -maxdepth 3 -type l | while IFS= read -r link; do \
      target="$(readlink -f "$link")"; \
      if [ -d "$target" ]; then \
        rm "$link" && cp -a "$target" "$link" && \
        echo "Resolved symlink: $link"; \
      elif [ -f "$target" ]; then \
        rm "$link" && cp -a "$target" "$link" && \
        echo "Resolved symlink: $link"; \
      fi; \
    done

# Prune prod deps and strip node_modules
RUN pnpm prune --prod && \
    find node_modules -maxdepth 4 \( \
        -name "*.md"        -o -name "*.MD"      \
        -o -name "*.txt"    -o -name "*.map"      \
        -o -name "CHANGELOG*" -o -name "LICENCE*" \
        -o -name "LICENSE"  -o -name "AUTHORS"    \
        -o -name ".travis.yml" -o -name ".eslintrc*" \
        -o -name "Makefile" -o -name "*.sh"       \
    \) -delete && \
    find node_modules -maxdepth 5 -type d \( \
        -name "__tests__" -o -name "test"  \
        -o -name "tests"  -o -name "spec"  \
        -o -name ".github" -o -name ".circleci" \
        -o -name "example" -o -name "examples"  \
    \) -exec rm -rf {} + 2>/dev/null || true && \
    find node_modules -maxdepth 6 -name "*.ts" ! -name "*.d.ts" -delete && \
    find node_modules -maxdepth 6 -name "*.js.map" -delete && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then \
      find node_modules -maxdepth 6 \( \
          -name "*darwin*" -o -name "*win32*" \
          -o -name "*freebsd*" -o -name "*linux-arm*" \
      \) -name "*.node" -delete 2>/dev/null || true; \
    else \
      find node_modules -maxdepth 6 \( \
          -name "*darwin*" -o -name "*win32*" \
          -o -name "*freebsd*" -o -name "*linux-x64*" \
      \) -name "*.node" -delete 2>/dev/null || true; \
    fi && \
    pnpm store prune --force 2>/dev/null || true

# ---------------------------------------------------------------------------
# Minimize attack surface — remove everything not needed at runtime.
# ---------------------------------------------------------------------------

# 1. Prune unselected extension dist and their exclusive node_modules deps.
RUN if [ -f scripts/prune-docker-plugin-dist.mjs ] && [ -f scripts/postinstall-bundled-plugins.mjs ] && [ -f /tmp/openclaw-plugin-selection-supported ]; then \
      OPENCLAW_EXTENSIONS="$(cat /tmp/openclaw-selected-plugin-dirs)" \
      OPENCLAW_BUNDLED_PLUGIN_DIR=extensions \
      node scripts/prune-docker-plugin-dist.mjs && \
      node scripts/postinstall-bundled-plugins.mjs; \
    fi

# 2. Remove ALL extension/package source (only compiled dist/ is needed).
RUN rm -rf extensions/ packages/ patches/

# 3. Strip build tooling, VCS metadata, and dev artifacts.
RUN rm -rf .git .github .gitignore .gitattributes \
           .eslintrc* .prettierrc* .editorconfig \
           tsconfig*.json \
           pnpm-lock.yaml package-lock.json yarn.lock \
           pnpm-workspace.yaml .npmrc openclaw.mjs \
           tests test __tests__ \
           scripts \
           examples \
           ui/src/ \
           CONTRIBUTING.md SECURITY.md CHANGELOG.md \
           /tmp/openclaw-selected-plugin-dirs 2>/dev/null || true

# 4. Remove .d.ts and source maps from dist.
RUN find dist -type f \( -name '*.d.ts' -o -name '*.d.mts' -o -name '*.d.cts' -o -name '*.map' \) -delete 2>/dev/null || true

# ---------------------------------------------------------------------------
# Stage 2: Node.js runtime provider
# The RHEL AI base image does not include Node.js. Pull the UBI Node.js 24
# image to extract the runtime binary and its shared libraries.
# ---------------------------------------------------------------------------
FROM docker.io/library/node:24-bookworm-slim@sha256:242549cd46785b480c832479a730f4f2a20865d61ea2e404fdb2a5c3d3b73ecf AS node-runtime

# ---------------------------------------------------------------------------
# Stage 3: Runtime — RHEL AI base image + Node.js
# ---------------------------------------------------------------------------
ARG CSB_BASE_IMAGE
FROM ${CSB_BASE_IMAGE} AS runtime

LABEL name="openclaw-csb" \
      maintainer="Ryan Nix <ryan.nix@gmail.com>" \
      summary="OpenClaw AI agent gateway — RHEL AI (CSB) for OpenShift" \
      description="OpenClaw built from source on RHEL AI base, for OpenShift restricted SCC" \
      io.k8s.display-name="OpenClaw CSB" \
      io.openshift.expose-services="18789:http" \
      io.openshift.tags="ai,agent,nodejs,rhelai,csb"

USER root

# Copy Node.js runtime + shared libraries from the UBI nodejs-24 image.
# Includes node binary, npm, and all required .so files (libnode, libuv, etc.)
# Override the base image's Node.js with the upstream version.
# The RHEL AI base ships Node 24.18.0 with SQLite 3.46.1, which OpenClaw
# rejects due to the WAL-reset corruption bug. The bookworm-slim Node
# has the correct SQLite version.
COPY --from=node-runtime /usr/local/bin/node /usr/bin/node
RUN node --version

# Install gh CLI and curl — the only allowed executables for the CSB agent.
# gh is needed for GitHub API access (team-prs, PR review, issue lookup).
# curl is needed for HTTP API calls to approved domains.
RUN dnf install -y curl && dnf clean all && rm -rf /var/cache/dnf
RUN GH_VERSION="2.96.0" && \
    curl -sSfL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/').tar.gz" \
      -o gh.tar.gz && \
    tar xzf gh.tar.gz --strip-components=2 -C /usr/local/bin "gh_${GH_VERSION}_linux_$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')/bin/gh" && \
    rm gh.tar.gz && \
    gh --version

RUN mkdir -p /app /opt/openclaw/config /opt/openclaw/workspace && \
    chown -R 1001:0 /app /opt/openclaw && \
    chmod -R g=u /opt/openclaw && \
    chmod g+rwX /opt/openclaw /opt/openclaw/config /opt/openclaw/workspace

COPY --from=builder --chown=1001:0 /build /app

COPY --chown=1001:0 csb/entrypoint.sh /app/entrypoint.sh
RUN chmod 0755 /app/entrypoint.sh

ENV OPENCLAW_CONFIG_DIR=/opt/openclaw/config \
    OPENCLAW_WORKSPACE_DIR=/opt/openclaw/workspace \
    OPENCLAW_NIX_MODE=1 \
    NODE_ENV=production \
    HOME=/opt/openclaw \
    PATH=/app/node_modules/.bin:$PATH

WORKDIR /app

EXPOSE 18789

USER 1001

ENTRYPOINT ["/app/entrypoint.sh"]
