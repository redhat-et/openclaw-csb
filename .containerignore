# =============================================================================
# .containerignore — excludes files from the Containerfile build context
#
# These files are never needed inside the container and excluding them keeps
# the build context small (faster transfer to buildah/docker daemon) and
# prevents accidentally COPY'ing things that should not be in the image.
# =============================================================================

# Git history and metadata
.git
.gitignore
.gitattributes

# CI/CD
.github

# Ansible deployment files (runtime tooling, not part of the image)
deploy-openclaw.yml
vars/
templates/
skills/

# Documentation
README.md
*.md

# Local development
.env
.env.*
*.local

# Container build artifacts
Containerfile
.containerignore

# Editor / OS noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

