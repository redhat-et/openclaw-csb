ARG BASE_IMAGE=registry.access.redhat.com/ubi10/ubi-minimal:10.2
FROM ${BASE_IMAGE}

ARG BASE_IMAGE_REVISION=1

ARG VARIANT=base
ARG NAME=agentic-base
ARG SUMMARY="Red Hat AI Agentic Base Image"

LABEL io.openshell.sandbox.harness="${VARIANT}" \
      name="${NAME}" \
      com.redhat.component="${NAME}-container" \
      summary="${SUMMARY}" \
      description="${SUMMARY}" \
      io.k8s.display-name="${SUMMARY}" \
      io.k8s.description="${SUMMARY}" \
      io.openshift.tags="ubi ${VARIANT} ${NAME}"

# Minimal system packages required for agent harness operation
# iproute is required by OpenShell's network namespace isolation
RUN microdnf install -y --nodocs --setopt=install_weak_deps=0 \
    ca-certificates \
    curl \
    git \
    tar \
    gzip \
    shadow-utils \
    findutils \
    iproute && \
    microdnf clean all && \
    rm -rf /var/cache/yum

# Users: sandbox (interactive, OpenShift/OpenShell-compatible)
# OpenShell requires both a sandbox user AND a sandbox group.
RUN groupadd -g 1001 sandbox && \
    useradd -u 1001 -g 0 -G sandbox -m -d /sandbox -s /bin/bash sandbox

# Sandbox home structure
RUN mkdir -p \
    /sandbox/.local/bin \
    /sandbox/.venv \
    /sandbox/.config \
    /sandbox/.cache \
    /sandbox/.agents/skills && \
    chown -R 1001:0 /sandbox && \
    chmod -R g=u /sandbox

# ARC: sidecar-owned paths
RUN mkdir -p \
    /etc/openshell/spiffe \
    /etc/openshell/otel \
    /etc/openshell/agents

# Default OpenShell policy
COPY policy.yaml /etc/openshell/policy.yaml

# Entrypoint
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1001
WORKDIR /sandbox
ENV HOME=/sandbox
ENV PATH="/sandbox/.venv/bin:/sandbox/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
